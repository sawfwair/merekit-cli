{
  "name": "@merekit/cli",
  "version": "0.5.2",
  "description": "Public Mere command plane with waitlist and invite onboarding, bundled app adapters, agent context packs, audits, and MCP access.",
  "private": false,
  "license": "Apache-2.0",
  "type": "module",
  "author": "Sawfwair",
  "homepage": "https://sawfwair.github.io/merekit-cli/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sawfwair/merekit-cli.git"
  },
  "bugs": {
    "url": "https://github.com/sawfwair/merekit-cli/issues"
  },
  "keywords": [
    "mere",
    "merekit",
    "cli",
    "mcp",
    "agents",
    "onboarding",
    "waitlist",
    "command-plane",
    "workspaces",
    "vitepress"
  ],
  "bin": {
    "mere": "dist/run.js"
  },
  "files": [
    "dist",
    "adapters",
    "docs/**/*.md",
    "docs/public",
    "skills",
    "npm-shrinkwrap.json",
    "CHANGELOG.md",
    "CODEBASE.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "DECISIONS.md",
    "LICENSE",
    "NOTICE",
    "README.md",
    "SECURITY.md",
    "SUPPORT.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "overrides": {
    "fast-uri": "3.1.2",
    "hono": "4.12.23",
    "qs": "6.15.2"
  },
  "pnpm": {
    "overrides": {
      "@vitejs/plugin-vue": "6.0.6",
      "esbuild": "0.28.0",
      "fast-uri": "3.1.2",
      "hono": "4.12.23",
      "qs": "6.15.2",
      "vite": "6.4.2"
    }
  },
  "scripts": {
    "prepack": "pnpm build",
    "build": "tsc -p tsconfig.json",
    "build:adapters": "node scripts/build-adapters.mjs",
    "check": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --max-warnings 0",
    "coverage": "pnpm build && c8 --config c8.config.json node --test test/*.test.mjs",
    "check:package": "node scripts/check-package-contents.mjs",
    "check:adapters": "pnpm build && node scripts/check-adapter-coverage.mjs && node scripts/check-adapter-safety.mjs",
    "check:supply-chain": "node scripts/check-supply-chain.mjs",
    "check:lockfile-guard": "node scripts/check-lockfile-guard.mjs",
    "test": "pnpm build && node --test test/*.test.mjs",
    "smoke": "pnpm build && node dist/run.js --help >/dev/null && node dist/run.js completion bash >/dev/null && node dist/run.js apps list --json >/dev/null && node scripts/mcp-tools-smoke.mjs",
    "smoke:mcp": "pnpm build && node scripts/mcp-tools-smoke.mjs",
    "verify": "pnpm lint && pnpm check && pnpm check:supply-chain && pnpm test && pnpm coverage && pnpm check:adapters && pnpm smoke && pnpm smoke:mcp && pnpm check:package",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:worker:test": "node --test docs-worker/*.test.mjs",
    "docs:worker:dry-run": "DOCS_BASE=/ pnpm docs:build && npx --yes wrangler@4.97.0 deploy -c wrangler.docs.jsonc --dry-run",
    "docs:deploy": "DOCS_BASE=/ pnpm docs:build && npx --yes wrangler@4.97.0 deploy -c wrangler.docs.jsonc",
    "prepublishOnly": "pnpm build && pnpm check:package",
    "pack:dry": "pnpm verify && pnpm docs:build && npm pack --dry-run --ignore-scripts",
    "test:pack": "node scripts/test-pack.mjs",
    "start": "node dist/run.js",
    "build:adapters:internal": "node scripts/build-adapters.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "sqlite-vec": "0.1.9",
    "yaml": "2.8.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.9.1",
    "c8": "11.0.0",
    "esbuild": "0.28.1",
    "eslint": "10.3.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2",
    "vitepress": "1.6.4"
  },
  "engines": {
    "node": ">=24 <26"
  },
  "packageManager": "pnpm@10.8.1"
}
