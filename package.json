{
  "name": "@merekit/cli",
  "version": "0.1.13",
  "private": false,
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "mere": "dist/run.js"
  },
  "files": [
    "dist",
    "adapters",
    "docs/**/*.md",
    "docs/public",
    "skills",
    "LICENSE",
    "README.md",
    "SECURITY.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "pnpm build",
    "build": "tsc -p tsconfig.json",
    "build:adapters": "node scripts/build-adapters.mjs",
    "check": "tsc --noEmit -p tsconfig.json",
    "check:package": "node scripts/check-package-contents.mjs",
    "check:adapters": "pnpm build && node scripts/check-adapter-safety.mjs",
    "test": "pnpm build && node --test test/*.test.mjs",
    "smoke": "pnpm build && node dist/run.js --help >/dev/null && node dist/run.js completion bash >/dev/null && node dist/run.js apps list --json >/dev/null && node scripts/mcp-tools-smoke.mjs",
    "smoke:mcp": "pnpm build && node scripts/mcp-tools-smoke.mjs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepublishOnly": "pnpm build && pnpm check:package",
    "pack:dry": "pnpm check && pnpm test && pnpm smoke && pnpm check:adapters && pnpm check:package && npm pack --dry-run --ignore-scripts",
    "test:pack": "node scripts/test-pack.mjs",
    "start": "node dist/run.js",
    "build:adapters:internal": "node scripts/build-adapters.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3",
    "vitepress": "1.6.4"
  },
  "engines": {
    "node": ">=24 <26"
  },
  "packageManager": "pnpm@10.8.1"
}
