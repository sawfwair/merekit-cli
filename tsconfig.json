{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"exactOptionalPropertyTypes": true,
		"noImplicitReturns": true,
		"noUncheckedIndexedAccess": true,
		"esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "rootDir": "src",
    "outDir": "dist",
    "types": ["node"]
  },
  "include": ["src/**/*.ts"]
}
